# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.

# Neon PostgreSQL — use the POOLING URL (pgbouncer, port 6543)
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# UPI ID for payment QR code (e.g. yourname@upi)
UPI_ID=yourshop@upi

# Shop name printed on receipts and QR code
SHOP_NAME=My Smart Trolley Shop

# Razorpay credentials (keep for legacy payment flow)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxx
