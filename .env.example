# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit real secrets.

# Neon PostgreSQL — use the POOLING URL (pgbouncer, port 6543)
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://neondb_owner:npg_rL0wjihIpxq2@ep-morning-block-amj0msp8-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# UPI ID for payment QR code (e.g. yourname@upi)
UPI_ID=test@ybl@upi

# Shop name printed on receipts and QR code
SHOP_NAME=My Smart Trolley Shop

# Bluetooth thermal printer MAC address (example format: AA:BB:CC:DD:EE:FF)
BLUETOOTH_PRINTER_MAC=D9:2C:4C:B4:DA:FF
# Optional raw Bluetooth printer tuning
BT_PRINTER_CHANNEL=1
BT_PRINTER_ROW_DELAY_SECONDS=0.005
BT_PRINTER_WIDTH=384

# Razorpay credentials (keep for legacy payment flow)
RAZORPAY_KEY_ID="rzp_test_SDiqKHyr1tduXG"
RAZORPAY_KEY_SECRET="5pFqUdxICfF7FrxPTj6Nuu7c"

TFT_REINIT_SECONDS=0

# Scanner button wiring:
# - physical pin 11 (BCM17) to one side of button
# - physical pin 39 (GND) to the other side of button
SCANNER_BUTTON_ENABLED=1
SCANNER_BUTTON_PIN_MODE=board
SCANNER_BUTTON_PIN=11
SCANNER_BUTTON_BOUNCETIME_MS=250
LOW_STOCK_THRESHOLD=5

# Optional checkout button aliases (fallback to SCANNER_BUTTON_* when omitted).
# Use BCM mode and GPIO16 as placeholder if wiring is not finalized.
# CHECKOUT_BUTTON_ENABLED=1
# CHECKOUT_BUTTON_PIN_MODE=bcm
# CHECKOUT_BUTTON_PIN=16
# CHECKOUT_BUTTON_BOUNCETIME_MS=300